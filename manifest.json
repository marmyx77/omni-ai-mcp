{
  "dxt_version": "0.1",
  "name": "omni-ai-mcp",
  "display_name": "Omni AI MCP",
  "version": "4.0.2",
  "description": "Multi-AI MCP bridge: Gemini + 400+ models via OpenRouter. 20 tools: text generation, code review, image, video, TTS, RAG, Deep Research.",
  "author": {
    "name": "Marco Armellino",
    "url": "https://github.com/marmyx77"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marmyx77/omni-ai-mcp"
  },
  "license": "MIT",
  "server": {
    "type": "python",
    "entry_point": "server/run.py",
    "mcp_config": {
      "command": "python3",
      "args": ["${__dirname}/server/run.py"],
      "env": {
        "GEMINI_API_KEY": "${user_config.gemini_api_key}",
        "OPENROUTER_API_KEY": "${user_config.openrouter_api_key}",
        "PYTHONPATH": "${__dirname}/lib"
      }
    }
  },
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"],
    "runtimes": {
      "python": ">=3.9,<4.0"
    }
  },
  "user_config": {
    "gemini_api_key": {
      "type": "string",
      "title": "Google Gemini API Key",
      "description": "Required. Get yours at https://aistudio.google.com/app/apikey",
      "sensitive": true,
      "required": true
    },
    "openrouter_api_key": {
      "type": "string",
      "title": "OpenRouter API Key",
      "description": "Optional. Enables 400+ models (GPT-4o, Llama, Mistral, Claude via OR). Get yours at https://openrouter.ai/keys",
      "sensitive": true,
      "required": false
    }
  }
}
